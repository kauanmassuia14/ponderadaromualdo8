# ======================================================
# main_aws.tf.example
# ======================================================
# Esta é a versão ORIGINAL do main.tf conforme o tutorial
# oficial da HashiCorp para uso com uma conta AWS REAL.
#
# Para usar este arquivo em produção:
#   1. Renomeie para main.tf (substituindo o atual)
#   2. Configure suas credenciais AWS:
#      export AWS_ACCESS_KEY_ID="sua-chave"
#      export AWS_SECRET_ACCESS_KEY="seu-segredo"
#   3. Execute: terraform init && terraform apply
# ======================================================

provider "aws" {
  region = "us-west-2"
}

data "aws_ami" "ubuntu" {
  most_recent = true

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd-gp3/ubuntu-noble-24.04-amd64-server-*"]
  }

  owners = ["099720109477"] # Canonical
}

resource "aws_instance" "app_server" {
  ami           = data.aws_ami.ubuntu.id
  instance_type = "t2.micro"

  tags = {
    Name = "learn-terraform"
  }
}
